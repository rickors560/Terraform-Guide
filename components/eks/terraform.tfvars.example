# EKS Component — Example Variable Values
# Copy this file to terraform.tfvars and adjust values for your environment.

aws_region             = "ap-south-1"
project_name           = "myapp"
environment            = "dev"
vpc_id                 = "vpc-xxxxxxxxxxxxxxxxx"
private_subnet_ids     = ["subnet-priv-a", "subnet-priv-b", "subnet-priv-c"]
cluster_version        = "1.31"
endpoint_public_access = true
public_access_cidrs    = ["0.0.0.0/0"]  # Restrict in production
cluster_log_types      = ["api", "audit", "authenticator", "controllerManager", "scheduler"]
kms_key_arn            = ""
log_retention_days     = 30
node_instance_types    = ["t3.medium"]
node_capacity_type     = "ON_DEMAND"
node_disk_size         = 50
node_desired_size      = 2
node_min_size          = 1
node_max_size          = 5
