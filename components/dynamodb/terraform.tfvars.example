# DynamoDB Component — Example Variable Values
# Copy this file to terraform.tfvars and adjust values for your environment.

aws_region     = "ap-south-1"
project_name   = "myapp"
environment    = "dev"
table_name     = "main"
billing_mode   = "PAY_PER_REQUEST"    # Or "PROVISIONED" with auto-scaling
hash_key       = "PK"
hash_key_type  = "S"
range_key      = "SK"
range_key_type = "S"
ttl_enabled    = true
ttl_attribute  = "ExpiresAt"
pitr_enabled   = true
stream_enabled = false
kms_key_arn    = ""

# Provisioned mode settings (ignored for PAY_PER_REQUEST)
read_capacity      = 5
write_capacity     = 5
enable_autoscaling = false
