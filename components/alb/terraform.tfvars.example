# ALB Component — Example Variable Values
aws_region          = "ap-south-1"
project_name        = "myapp"
environment         = "dev"
vpc_id              = "vpc-xxxxxxxxxxxxxxxxx"
subnet_ids          = ["subnet-pub-a", "subnet-pub-b"]
internal            = false
acm_certificate_arn = ""    # Set for HTTPS
target_port         = 80
target_type         = "instance"
health_check_path   = "/"
enable_access_logs  = true
