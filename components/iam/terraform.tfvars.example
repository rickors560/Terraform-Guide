# -----------------------------------------------------------------------------
# IAM Component - Example Variable Values
# -----------------------------------------------------------------------------
# Copy this file to terraform.tfvars and update the values for your environment.
# -----------------------------------------------------------------------------

region       = "ap-south-1"
project_name = "myproject"
environment  = "dev"

iam_users = {
  "john.doe" = {
    department = "engineering"
    group      = "admin"
  }
  "jane.smith" = {
    department = "engineering"
    group      = "developer"
  }
  "bob.wilson" = {
    department = "finance"
    group      = "readonly"
  }
}

# Cross-account role configuration
trusted_account_ids = []
# trusted_account_ids = ["123456789012", "987654321098"]

# GitHub OIDC configuration
enable_github_oidc  = false
github_repositories = []
# enable_github_oidc  = true
# github_repositories = ["my-org/my-repo", "my-org/another-repo"]
