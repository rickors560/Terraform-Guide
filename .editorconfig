root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Terraform (HCL)
[*.{tf,tfvars}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Markdown
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Makefiles require tabs
[Makefile]
indent_style = tab
indent_size = 4

# Java
[*.java]
indent_size = 4

# Python
[*.py]
indent_size = 4

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2

# JavaScript / TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# HTML / CSS
[*.{html,css,scss}]
indent_size = 2

# Kubernetes manifests
[k8s/**/*.{yml,yaml}]
indent_size = 2

# Helm templates
[*.tpl]
indent_size = 2

# Dockerfiles
[Dockerfile*]
indent_size = 2
